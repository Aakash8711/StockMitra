{
  "cleanUrls": true,
  "redirects": [
    { "source": "/frontend/html", "destination": "/", "permanent": true },
    { "source": "/frontend/html/index.html", "destination": "/", "permanent": true },
    { "source": "/frontend/html/:path.html", "destination": "/:path", "permanent": true },
    { "source": "/frontend/html/:path", "destination": "/:path", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/frontend/html/index.html" },
    { "source": "/signup", "destination": "/frontend/html/signup.html" },
    { "source": "/dashboard", "destination": "/frontend/html/dashboard.html" },
    { "source": "/sales", "destination": "/frontend/html/sales.html" }
  ]
}
